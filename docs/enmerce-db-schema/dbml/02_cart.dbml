// ============================================================
// DATABASE: enmerce_cart
// Shopping cart state, TTL for abandoned carts
// Visualize: paste vào https://dbdiagram.io
// ============================================================

Project enmerce_cart {
  database_type: 'PostgreSQL'
  Note: '''
    # Cart Database
    User shopping cart state. High read/write frequency.
    Auto-expiry for abandoned carts (7 days TTL).
  '''
}

Table carts {
  id            uuid [pk, default: `gen_random_uuid()`]
  user_id       uuid [not null]
  merchant_id   uuid [not null, note: 'cart scoped per merchant']
  status        varchar(20) [not null, default: 'active', note: 'active|converted|expired']
  currency_code char(3) [not null, default: 'VND']
  subtotal      decimal(15,2) [not null, default: 0]
  item_count    int [not null, default: 0]
  notes         text
  metadata      jsonb [default: '{}']
  expires_at    timestamptz [not null, default: `now() + interval '7 days'`]
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]
  version       int [not null, default: 1]

  indexes {
    (user_id, merchant_id, status) [name: 'idx_carts_user', note: 'WHERE status = active']
    (expires_at) [name: 'idx_carts_expires']
  }
}

Table cart_items {
  id                     uuid [pk, default: `gen_random_uuid()`]
  cart_id                uuid [not null, ref: > carts.id]
  product_id             uuid [not null, note: 'cross-service ref to catalog']
  variant_id             uuid [note: 'cross-service ref to catalog variant']
  merchant_id            uuid [not null]
  quantity               int [not null, note: '> 0 AND <= 999']
  unit_price_snapshot    decimal(15,2) [not null, note: 'price when added']
  product_name_snapshot  varchar(500) [not null, note: 'name when added']
  variant_label_snapshot varchar(255)
  image_url_snapshot     text
  metadata               jsonb [default: '{}']
  added_at               timestamptz [not null, default: `now()`]
  updated_at             timestamptz [not null, default: `now()`]

  indexes {
    (cart_id, product_id, variant_id) [unique]
    (cart_id) [name: 'idx_ci_cart']
  }
}

