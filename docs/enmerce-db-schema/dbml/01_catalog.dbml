// ============================================================
// DATABASE: enmerce_catalog
// Multi-merchant, multi-language product catalog
// Visualize: paste vào https://dbdiagram.io
// ============================================================

Project enmerce_catalog {
  database_type: 'PostgreSQL'
  Note: '''
    # Catalog Database
    Multi-merchant, multi-language product catalog.
    Read-heavy workload. RLS for merchant isolation.
  '''
}

// ─── MERCHANTS ──────────────────────────────────────────────

Table merchants {
  id              uuid [pk, default: `gen_random_uuid()`]
  code            varchar(50) [unique, not null, note: 'merchant slug']
  logo_url        text
  banner_url      text
  email_encrypted bytea [note: '🔒 FLE via Vault Transit']
  phone_encrypted bytea [note: '🔒 FLE via Vault Transit']
  status          varchar(20) [not null, default: 'pending', note: 'pending|active|suspended|closed']
  rating_avg      decimal(3,2) [default: 0.00]
  rating_count    int [default: 0]
  commission_rate decimal(5,4) [not null, default: 0.0500, note: '5% default']
  is_verified     boolean [not null, default: false]
  metadata        jsonb [default: '{}']
  created_at      timestamptz [not null, default: `now()`]
  updated_at      timestamptz [not null, default: `now()`]
  created_by      uuid
  updated_by      uuid
  deleted_at      timestamptz
  is_active       boolean [not null, default: true]
  version         int [not null, default: 1, note: 'optimistic locking']

  indexes {
    (status) [name: 'idx_merchants_status', note: 'WHERE is_active = true']
    (code) [name: 'idx_merchants_code']
  }
}


Table merchant_addresses {
  id                uuid [pk, default: `gen_random_uuid()`]
  merchant_id       uuid [not null, ref: > merchants.id]
  address_type      varchar(20) [not null, note: 'warehouse|office|return']
  address_encrypted bytea [not null, note: '🔒 FLE']
  city              varchar(100)
  state_province    varchar(100)
  country_code      char(2) [not null, note: 'ISO 3166-1 alpha-2']
  postal_code       varchar(20)
  is_default        boolean [not null, default: false]
  created_at        timestamptz [not null, default: `now()`]
  updated_at        timestamptz [not null, default: `now()`]

  indexes {
    (merchant_id) [name: 'idx_merchant_addr_merchant']
  }
}

// ─── CATEGORIES (Materialized Path) ─────────────────────────

Table categories {
  id         uuid [pk, default: `gen_random_uuid()`]
  parent_id  uuid [ref: > categories.id, note: 'self-referencing tree']
  path       text [not null, note: 'materialized path: /root/electronics/phones']
  depth      smallint [not null, default: 0]
  sort_order int [not null, default: 0]
  icon_url   text
  is_active  boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (parent_id) [name: 'idx_cat_parent']
  }
}

// ─── PRODUCTS ───────────────────────────────────────────────

Table products {
  id            uuid [pk, default: `gen_random_uuid()`]
  merchant_id   uuid [not null, ref: > merchants.id]
  sku           varchar(100) [not null]
  status        varchar(20) [not null, default: 'draft', note: 'draft|pending_review|active|inactive|archived']
  product_type  varchar(20) [not null, default: 'physical', note: 'physical|digital|service']
  base_price    decimal(15,2) [not null, note: '>= 0']
  currency_code char(3) [not null, default: 'VND', note: 'ISO 4217']
  weight_grams  int
  is_taxable    boolean [not null, default: true]
  tax_class     varchar(50) [default: 'standard']
  brand         varchar(255)
  metadata      jsonb [default: '{}', note: 'flexible product attrs']
  images        jsonb [default: '[]', note: '[{"url":"...","alt":"...","is_primary":true,"sort_order":0}]']
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]
  created_by    uuid
  updated_by    uuid
  deleted_at    timestamptz
  is_active     boolean [not null, default: true]
  version       int [not null, default: 1]

  indexes {
    (merchant_id, sku) [unique]
    (merchant_id) [name: 'idx_prod_merchant']
    (status) [name: 'idx_prod_status']
    (base_price) [name: 'idx_prod_price']
  }

  Note: 'RLS enabled for merchant isolation'
}

Table product_categories {
  product_id  uuid [not null, ref: > products.id]
  category_id uuid [not null, ref: > categories.id]
  is_primary  boolean [not null, default: false]
  sort_order  int [not null, default: 0]

  indexes {
    (product_id, category_id) [pk]
  }
}



// ─── ATTRIBUTES & VARIANTS ──────────────────────────────────

Table attributes {
  id            uuid [pk, default: `gen_random_uuid()`]
  code          varchar(100) [unique, not null, note: 'color, size, material']
  data_type     varchar(20) [not null, note: 'text|number|boolean|select|multi_select|color']
  is_filterable boolean [not null, default: false]
  is_required   boolean [not null, default: false]
  sort_order    int [not null, default: 0]
  validation    jsonb [note: '{"min":0,"max":100,"options":["S","M","L"]}']
  created_at    timestamptz [not null, default: `now()`]
  updated_at    timestamptz [not null, default: `now()`]
}


Table product_variants {
  id               uuid [pk, default: `gen_random_uuid()`]
  product_id       uuid [not null, ref: > products.id]
  sku              varchar(100) [not null]
  price_override   decimal(15,2) [note: 'NULL = use base_price']
  compare_at_price decimal(15,2) [note: 'original price for sale display']
  weight_grams     int
  barcode          varchar(100) [note: 'EAN/UPC']
  images           jsonb [default: '[]', note: '[{"url":"...","alt":"...","is_primary":true,"sort_order":0}]']
  is_active        boolean [not null, default: true]
  sort_order       int [not null, default: 0]
  created_at       timestamptz [not null, default: `now()`]
  updated_at       timestamptz [not null, default: `now()`]
  version          int [not null, default: 1]

  indexes {
    (product_id, sku) [unique]
    (product_id) [name: 'idx_var_product']
    (barcode) [name: 'idx_var_barcode']
  }
}


Table variant_attribute_values {
  id           uuid [pk, default: `gen_random_uuid()`]
  variant_id   uuid [not null, ref: > product_variants.id]
  attribute_id uuid [not null, ref: > attributes.id]
  value_text   text
  value_numeric decimal(15,4)

  indexes {
    (variant_id, attribute_id) [unique]
    (attribute_id, value_text) [name: 'idx_vav_filter']
  }
}

// ─── REVIEWS ────────────────────────────────────────────────

Table product_reviews {
  id             uuid [pk, default: `gen_random_uuid()`]
  product_id     uuid [not null, ref: > products.id]
  user_id        uuid [not null, note: 'from auth service (Keycloak)']
  order_id       uuid [note: 'cross-service ref for verified purchase']
  rating         smallint [not null, note: '1-5']
  title          varchar(255)
  content        text
  is_verified    boolean [not null, default: false, note: 'verified purchase']
  is_approved    boolean [not null, default: false, note: 'moderated']
  helpful_count  int [not null, default: 0]
  images         jsonb [default: '[]']
  merchant_reply text
  replied_at     timestamptz
  created_at     timestamptz [not null, default: `now()`]
  updated_at     timestamptz [not null, default: `now()`]
  deleted_at     timestamptz

  indexes {
    (product_id, is_approved, created_at) [name: 'idx_rev_product']
    (user_id) [name: 'idx_rev_user']
  }
}

// ─── AUDIT LOG ──────────────────────────────────────────────

Table catalog_audit_log {
  id               uuid [pk, default: `gen_random_uuid()`]
  table_name       varchar(100) [not null, note: 'merchants|products|categories|product_reviews|product_variants']
  record_id        uuid [not null, note: 'PK of affected record']
  action           varchar(10) [not null, note: 'INSERT|UPDATE|DELETE']
  old_data         jsonb [note: 'state trước khi thay đổi (NULL for INSERT)']
  new_data         jsonb [note: 'state sau khi thay đổi (NULL for DELETE)']
  changed_fields   text[] [note: 'list of changed column names — fast filtering']
  actor_id         uuid [note: 'user/admin/system who made the change']
  actor_type       varchar(20) [note: 'user|merchant|admin|system|migration']
  ip_address       inet [note: 'STRIDE R: non-repudiation']
  user_agent       text
  correlation_id   varchar(255) [note: 'ELK trace_id — bidirectional PG ↔ ELK tracing']
  hmac_signature   varchar(128) [note: 'STRIDE T-DB-02: tamper detection via Vault Transit']
  hmac_key_version int [not null, default: 1, note: 'Vault key version for rotation support']
  created_at       timestamptz [not null, default: `now()`]

  indexes {
    (table_name, record_id) [name: 'idx_cat_audit_record']
    (actor_id) [name: 'idx_cat_audit_actor']
    (created_at) [name: 'idx_cat_audit_time']
  }

  Note: '''
    Append-only, partitioned by RANGE(created_at) monthly.
    HMAC via Vault Transit (cached key, TTL 5 min) for integrity.
    Tracks: merchants (status/commission), products (price/status),
    categories (tree restructure), product_reviews (moderation).
    Retention: 3 năm (Hot 6m → Warm 24m → Cold 36m).
    Populated by PostgreSQL trigger (hybrid approach).
  '''
}

