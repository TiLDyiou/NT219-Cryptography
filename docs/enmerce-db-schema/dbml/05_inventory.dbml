// ============================================================
// DATABASE: enmerce_inventory
// Marketplace inventory tracking, reservations, warehouse registry
// Visualize: paste vào https://dbdiagram.io
// ============================================================

Project enmerce_inventory {
  database_type: 'PostgreSQL'
  Note: '''
    # Inventory Database
    Marketplace inventory tracking with optimistic locking (STRIDE T-MS-02).
    Reservation system for checkout saga.
    Merchant manages physical stock, platform tracks available quantity.
  '''
}

Table warehouses {
  id                uuid [pk, default: `gen_random_uuid()`]
  merchant_id       uuid [not null]
  code              varchar(50) [not null]
  name              varchar(255) [not null]
  address_encrypted bytea [note: 'FLE']
  city              varchar(100)
  country_code      char(2) [not null]
  is_active         boolean [not null, default: true]
  priority          int [not null, default: 0, note: 'fulfillment priority']
  metadata          jsonb [default: '{}']
  created_at        timestamptz [not null, default: `now()`]
  updated_at        timestamptz [not null, default: `now()`]

  indexes {
    (merchant_id, code) [unique]
  }
}

Table inventory_items {
  id                 uuid [pk, default: `gen_random_uuid()`]
  product_id         uuid [not null, note: 'cross-service ref to Catalog']
  variant_id         uuid [note: 'cross-service ref to Catalog variant']
  warehouse_id       uuid [not null, ref: > warehouses.id]
  merchant_id        uuid [not null]
  sku                varchar(100) [not null]
  quantity_on_hand   int [not null, default: 0, note: '>= 0']
  quantity_reserved  int [not null, default: 0, note: '>= 0']
  quantity_available int [not null, note: 'GENERATED: on_hand - reserved']
  is_track_inventory boolean [not null, default: true]
  created_at         timestamptz [not null, default: `now()`]
  updated_at         timestamptz [not null, default: `now()`]
  version            int [not null, default: 1, note: 'STRIDE T-MS-02: optimistic locking']

  indexes {
    (product_id, variant_id, warehouse_id) [unique]
    (product_id, variant_id) [name: 'idx_inv_product']
    (merchant_id) [name: 'idx_inv_merchant']
  }
}

Table inventory_reservations {
  id                uuid [pk, default: `gen_random_uuid()`]
  inventory_item_id uuid [not null, ref: > inventory_items.id]
  order_id          uuid [not null, note: 'cross-service ref to Order']
  saga_id           uuid [note: 'cross-service ref to saga_state']
  quantity          int [not null, note: '> 0']
  status            varchar(20) [not null, default: 'held', note: 'held|confirmed|released|expired']
  held_at           timestamptz [not null, default: `now()`]
  expires_at        timestamptz [not null, default: `now() + interval '15 minutes'`]
  confirmed_at      timestamptz
  released_at       timestamptz
  release_reason    varchar(50)

  indexes {
    (inventory_item_id, status) [name: 'idx_res_item']
    (order_id) [name: 'idx_res_order']
    (expires_at) [name: 'idx_res_expires', note: 'WHERE status = held']
  }

  Note: 'Temporary holds during checkout. 15-minute TTL. Auto-release via cron.'
}

// ─── AUDIT LOG ──────────────────────────────────────────────
// Track MỌI thay đổi trên warehouses & inventory_items (bao gồm quantity changes).

Table inventory_audit_log {
  id               uuid [pk, default: `gen_random_uuid()`]
  table_name       varchar(100) [not null, note: 'warehouses|inventory_items']
  record_id        uuid [not null, note: 'PK of affected record']
  action           varchar(10) [not null, note: 'INSERT|UPDATE|DELETE']
  old_data         jsonb [note: 'state trước khi thay đổi (NULL for INSERT)']
  new_data         jsonb [note: 'state sau khi thay đổi (NULL for DELETE)']
  changed_fields   text[] [note: 'list of changed column names — fast filtering']
  actor_id         uuid [note: 'user/admin/system who made the change']
  actor_type       varchar(20) [note: 'user|merchant|admin|system|migration']
  ip_address       inet [note: 'STRIDE R: non-repudiation']
  user_agent       text
  correlation_id   varchar(255) [note: 'ELK trace_id — bidirectional PG ↔ ELK tracing']
  hmac_signature   varchar(128) [note: 'STRIDE T-DB-02: tamper detection via Vault Transit']
  hmac_key_version int [not null, default: 1, note: 'Vault key version for rotation support']
  created_at       timestamptz [not null, default: `now()`]

  indexes {
    (table_name, record_id) [name: 'idx_inv_audit_record']
    (actor_id) [name: 'idx_inv_audit_actor']
    (created_at) [name: 'idx_inv_audit_time']
  }

  Note: '''
    Append-only, partitioned by RANGE(created_at) monthly.
    HMAC via Vault Transit (cached key, TTL 5 min) for integrity.
    Track MỌI thay đổi trên warehouses & inventory_items:
    - Warehouse config: priority, is_active, address
    - Inventory config: is_track_inventory toggle
    - Quantity changes: quantity_on_hand updates (merchant API hoặc system)
    Marketplace model: platform không quản lý kho chi tiết,
    chỉ ghi nhận merchant thay đổi quantity qua API.
    Retention: 2 năm (Hot 6m → Warm 24m).
    Populated by PostgreSQL trigger (hybrid approach).
  '''
}
