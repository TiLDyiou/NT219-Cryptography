// ============================================================
// DATABASE: enmerce_shipping
// Carrier integration, shipment tracking
// Visualize: paste vào https://dbdiagram.io
// ============================================================

Project enmerce_shipping {
  database_type: 'PostgreSQL'
  Note: '''
    # Shipping Database
    Carrier integration (GHN, GHTK, J&T, FedEx).
    Real-time tracking events.
  '''
}

Table shipping_providers {
  id                  uuid [pk, default: `gen_random_uuid()`]
  code                varchar(50) [unique, not null, note: 'ghn|ghtk|jnt|fedex']
  name                varchar(255) [not null]
  api_base_url        text
  logo_url            text
  is_active           boolean [not null, default: true]
  supported_countries jsonb [default: '["VN"]']
  capabilities        jsonb [default: '{}', note: '{"tracking":true,"cod":true,"insurance":true}']
  metadata            jsonb [default: '{}']
  created_at          timestamptz [not null, default: `now()`]
  updated_at          timestamptz [not null, default: `now()`]
}

Table shipping_rates {
  id                      uuid [pk, default: `gen_random_uuid()`]
  provider_id             uuid [not null, ref: > shipping_providers.id]
  merchant_id             uuid [note: 'NULL = platform-wide rate']
  name                    varchar(255) [not null, note: 'Standard|Express|Same-day']
  rate_type               varchar(20) [not null, note: 'flat|weight_based|price_based|zone_based']
  base_rate               decimal(15,2) [not null]
  currency_code           char(3) [not null, default: 'VND']
  min_weight_grams        int [default: 0]
  max_weight_grams        int
  min_order_value         decimal(15,2) [default: 0]
  free_shipping_threshold decimal(15,2) [note: 'free shipping above this amount']
  estimated_days_min      int
  estimated_days_max      int
  zone_config             jsonb [note: 'zone-based pricing rules']
  is_active               boolean [not null, default: true]
  created_at              timestamptz [not null, default: `now()`]
  updated_at              timestamptz [not null, default: `now()`]

  indexes {
    (provider_id, is_active) [name: 'idx_sr_provider']
    (merchant_id) [name: 'idx_sr_merchant']
  }
}

Table shipments {
  id                        uuid [pk, default: `gen_random_uuid()`]
  order_id                  uuid [not null, note: 'cross-service ref to Order']
  merchant_id               uuid [not null]
  provider_id               uuid [not null, ref: > shipping_providers.id]
  rate_id                   uuid [ref: > shipping_rates.id]
  tracking_number           varchar(100)
  status                    varchar(30) [not null, default: 'pending', note: '''
    pending, label_created, picked_up, in_transit,
    out_for_delivery, delivered, failed_delivery,
    returned, cancelled
  ''']
  recipient_name_encrypted  bytea [not null, note: '🔒 FLE']
  recipient_phone_encrypted bytea [not null, note: '🔒 FLE']
  address_line1_encrypted   bytea [not null, note: '🔒 FLE']
  address_line2_encrypted   bytea [note: '🔒 FLE']
  city                      varchar(100) [not null]
  state_province            varchar(100)
  country_code              char(2) [not null]
  postal_code               varchar(20)
  weight_grams              int
  dimensions_cm             jsonb [note: '{"length":30,"width":20,"height":10}']
  package_count             int [not null, default: 1]
  shipping_cost             decimal(15,2) [not null]
  insurance_cost            decimal(15,2) [default: 0]
  cod_amount                decimal(15,2) [default: 0]
  estimated_delivery        date
  actual_delivery           timestamptz
  picked_up_at              timestamptz
  delivered_at              timestamptz
  provider_shipment_id      varchar(255)
  provider_label_url        text
  provider_response         jsonb
  special_instructions      text
  metadata                  jsonb [default: '{}']
  created_at                timestamptz [not null, default: `now()`]
  updated_at                timestamptz [not null, default: `now()`]
  version                   int [not null, default: 1]

  indexes {
    (order_id) [name: 'idx_ship_order']
    (tracking_number) [name: 'idx_ship_tracking']
    (merchant_id, status) [name: 'idx_ship_merchant']
    (status) [name: 'idx_ship_status', note: 'WHERE status NOT IN (delivered, cancelled)']
  }
}

Table shipment_tracking_events {
  id                uuid [pk, default: `gen_random_uuid()`]
  shipment_id       uuid [not null, ref: > shipments.id]
  event_code        varchar(50) [not null]
  event_description text [not null]
  location          varchar(255)
  occurred_at       timestamptz [not null]
  raw_data          jsonb [note: 'raw carrier API response']
  source            varchar(20) [not null, default: 'carrier', note: 'carrier|manual|system']
  created_at        timestamptz [not null, default: `now()`]

  indexes {
    (shipment_id, occurred_at) [name: 'idx_ste_shipment']
  }
}

// ─── AUDIT LOG ──────────────────────────────────────────────
// Table này track admin/config changes trên providers, rates, shipments.

Table shipping_audit_log {
  id               uuid [pk, default: `gen_random_uuid()`]
  table_name       varchar(100) [not null, note: 'shipping_providers|shipping_rates|shipments']
  record_id        uuid [not null, note: 'PK of affected record']
  action           varchar(10) [not null, note: 'INSERT|UPDATE|DELETE']
  old_data         jsonb [note: 'state trước khi thay đổi (NULL for INSERT)']
  new_data         jsonb [note: 'state sau khi thay đổi (NULL for DELETE)']
  changed_fields   text[] [note: 'list of changed column names — fast filtering']
  actor_id         uuid [note: 'user/admin/system who made the change']
  actor_type       varchar(20) [note: 'user|merchant|admin|system|migration']
  ip_address       inet [note: 'STRIDE R: non-repudiation']
  user_agent       text
  correlation_id   varchar(255) [note: 'ELK trace_id — bidirectional PG ↔ ELK tracing']
  hmac_signature   varchar(128) [note: 'STRIDE T-DB-02: tamper detection via Vault Transit']
  hmac_key_version int [not null, default: 1, note: 'Vault key version for rotation support']
  created_at       timestamptz [not null, default: `now()`]

  indexes {
    (table_name, record_id) [name: 'idx_ship_audit_record']
    (actor_id) [name: 'idx_ship_audit_actor']
    (created_at) [name: 'idx_ship_audit_time']
  }

  Note: '''
    Append-only, partitioned by RANGE(created_at) monthly.
    HMAC via Vault Transit (cached key, TTL 5 min) for integrity.
    Bổ sung cho shipment_tracking_events — track non-carrier changes:
    shipping_providers (enable/disable), shipping_rates (price change),
    shipments (manual status override, cod_amount modification).
    Retention: 2 năm (Hot 6m → Warm 24m).
    Populated by PostgreSQL trigger (hybrid approach).
  '''
}
