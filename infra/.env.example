# NT219 Crypto Capstone — Environment Variables Template
# Copy this file to .env and fill in real values
# .env is gitignored — never commit secrets

# PostgreSQL
POSTGRES_PASSWORD=changeme_dev

# Keycloak admin console credentials
KEYCLOAK_ADMIN_PASSWORD=admin_changeme

# Vault dev mode root token (known by design in dev mode — switch to real token in Week 5)
VAULT_DEV_ROOT_TOKEN=dev-root-token

# Grafana admin credentials
GRAFANA_ADMIN_PASSWORD=grafana_changeme
